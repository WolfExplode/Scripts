<resources>
  <resource name="YtDlpDlg" type="dialog">
    <dialog fontsize="9" height="214" lang="english" title="yt-dlp Downloader" width="430">

      <!-- URL -->
      <control halign="left" height="10" name="url_label" title="URL:" type="static" width="30" x="12" y="12"/>
      <control height="14" name="url_edit" type="edit" width="406" x="12" y="24"/>

      <!-- Mode -->
      <control halign="left" height="10" name="mode_label" title="Mode:" type="static" width="32" x="12" y="50"/>
      <control group="yes" height="12" name="audio_radio" title="Audio" type="radio" width="55" x="50" y="49"/>
      <control height="12" name="video_radio" title="Video" type="radio" width="55" x="110" y="49"/>

      <!-- Metadata -->
      <control height="12" name="metadata_check" title="Include metadata (embed thumbnail, subs, tags, chapters)" type="check" width="406" x="12" y="72"/>

      <!-- Cookies -->
      <control height="12" name="cookies_check" title="Use Firefox cookies (--cookies-from-browser firefox)" type="check" width="390" x="12" y="92"/>

      <!-- Overwrite -->
      <control height="12" name="overwrite_check" title="Overwrite if file already exists (--force-overwrites)" type="check" width="406" x="12" y="110"/>

      <!-- Update -->
      <control height="12" name="update_check" title="Update yt-dlp if not latest (pip install --upgrade yt-dlp)" type="check" width="406" x="12" y="128"/>

      <!-- PowerShell -->
      <control height="12" name="keepps_check" title="Keep PowerShell window open when finished (-NoExit)" type="check" width="406" x="12" y="146"/>

      <!-- Buttons -->
      <control close="1" default="yes" height="18" name="ok_btn" title="Download" type="button" width="80" x="258" y="178"/>
      <control close="2" height="18" name="cancel_btn" title="Cancel" type="button" width="66" x="352" y="178"/>

    </dialog>
  </resource>
</resources>
