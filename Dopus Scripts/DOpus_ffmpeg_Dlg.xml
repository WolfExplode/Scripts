<resources>
  <resource name="DOpus_ffmpeg_Dlg" type="dialog">
    <dialog fontsize="9" height="208" lang="english" title="Video/Audio Converter" width="360">
      <!-- Header -->
      <control halign="left" height="10" name="header_label" title="Convert selected files:" type="static" width="200" x="12" y="10"/>

      <!-- Mode Selection (Dropdown) -->
      <control halign="left" height="10" name="mode_label" title="Mode:" type="static" width="35" x="12" y="30"/>
      <control height="14" name="mode_combo" type="combo" width="100" x="55" y="28">
        <contents>
          <item text="Video" />
          <item text="Audio" />
        </contents>
      </control>

      <!-- Format Selection (Dropdown) - Will be populated dynamically -->
      <control halign="left" height="10" name="format_label" title="Format:" type="static" width="35" x="12" y="52"/>
      <control height="14" name="format_combo" type="combo" width="290" x="55" y="50">
        <!-- Items added dynamically by script -->
      </control>

      <!-- Quality (CRF) - used by some video formats -->
      <control halign="left" height="10" name="quality_label" title="Quality (CRF):" type="static" width="80" x="12" y="74"/>
      <control height="14" name="quality_edit" title="23" type="edit" width="80" x="95" y="72"/>
      <control halign="left" height="10" name="quality_hint" title="18–28 typical (lower = better quality)" type="static" width="260" x="12" y="90"/>

      <!-- Poster / thumbnail (separate from Convert) -->
      <control halign="left" height="10" name="thumb_header" title="Poster / cover image:" type="static" width="320" x="12" y="102"/>
      <control halign="left" height="10" name="thumb_hint" title="Set: one video (frame @ 2s) or Name.jpg + video.  Extract: one video." type="static" width="330" x="12" y="116"/>
      <control height="18" name="set_thumbnail_btn" title="Set thumbnail" type="button" width="100" x="12" y="130"/>
      <control height="18" name="extract_thumbnail_btn" title="Extract thumbnail" type="button" width="110" x="118" y="130"/>
      <control height="18" name="audio_mono_btn" title="Audio → mono" type="button" width="120" x="234" y="130"/>
      <control halign="left" height="10" name="split_av_hint" title="1 video: replace with video-only + .audio.mka. 1 video + 1 audio: remux to video filename, delete audio (-c copy)." type="static" width="330" x="12" y="148"/>
      <control height="18" name="split_av_btn" title="Split or combine audio and video" type="button" width="160" x="12" y="160"/>

      <!-- Buttons -->
      <control close="1" default="yes" height="18" name="ok_btn" title="Convert" type="button" width="70" x="150" y="180"/>
      <control close="2" height="18" name="cancel_btn" title="Cancel" type="button" width="70" x="230" y="180"/>
    </dialog>
  </resource>
</resources>
